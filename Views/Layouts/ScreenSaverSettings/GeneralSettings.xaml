<UserControl x:Class="ScreenSaver.Views.Layouts.ScreenSaverSettings.GeneralSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:l="clr-namespace:ScreenSaver.Views.Layouts.ScreenSaverSettings"
             mc:Ignorable="d" 
             xmlns:s="clr-namespace:ScreenSaver.Views.Models"
             xmlns:c="clr-namespace:ScreenSaver.Services.UI.Converters"
             xmlns:p="clr-namespace:Playnite"
             d:DataContext="{d:DesignInstance Type=s:ScreenSaverSettingsHandler}"
             d:DesignHeight="460">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
             <RowDefinition/>
            <RowDefinition Height="5"/>
            <RowDefinition/>
            <RowDefinition Height="5"/>
            <RowDefinition/>
            <RowDefinition Height="5"/>
            <RowDefinition/>
            <RowDefinition Height="5"/>
            <RowDefinition/>
            <RowDefinition Height="5"/>
            <RowDefinition/>
            <RowDefinition Height="5"/>
            <RowDefinition/>
            <RowDefinition Height="5"/>
            <RowDefinition/>
            <RowDefinition Height="5"/>
            <RowDefinition/>
            <RowDefinition Height="5"/>
            <RowDefinition/>
            <RowDefinition Height="5"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <CheckBox  Grid.Row="0" Grid.ColumnSpan="2" Name="CheckDisplayLogo"    IsChecked="{Binding Settings.DisplayLogo}"
                   Content="{p:LocalizedString {x:Static p:LocId.settings_display_logo}}"/>
        <CheckBox  Grid.Row="2" Grid.ColumnSpan="2" Name="CheckLogoSkip"       IsChecked="{Binding Settings.LogoSkip}"
                   Content="{p:LocalizedString {x:Static p:LocId.settings_logo_skip}}"              IsEnabled="{Binding ElementName=CheckDisplayLogo, Path=IsChecked}"/>
        <CheckBox  Grid.Row="4" Grid.ColumnSpan="2" Name="CheckBackgroundSkip" IsChecked="{Binding Settings.BackgroundSkip}"
                   Content="{p:LocalizedString {x:Static p:LocId.settings_bckgrd_skip}}"/>
        <CheckBox  Grid.Row="6" Grid.ColumnSpan="2" Name="CheckDisablePlay"    IsChecked="{Binding Settings.DisableWhilePlaying}"
                   Content="{p:LocalizedString {x:Static p:LocId.settings_disable_while_play}}"/>
        <CheckBox  Grid.Row="8" Grid.ColumnSpan="2" Name="CheckPauseOnDeac"    IsChecked="{Binding Settings.PauseOnDeactivate}"
                   Content="{p:LocalizedString {x:Static p:LocId.settings_pause_on_deac}}"/>
        <CheckBox  Grid.Row="10" Grid.ColumnSpan="2" Name="CheckDynGrpsInOr"    IsChecked="{Binding Settings.RetrieveDynamicGroupsInOrder}"
                   Content="{p:LocalizedString {x:Static p:LocId.settings_dynamic_sort}}" ToolTip="{p:LocalizedString {x:Static p:LocId.settings_dynamic_sort_tip}}"/>
        <StackPanel Grid.Row="12" Grid.ColumnSpan="2" Orientation="Horizontal">
            <l:UIntDUp Value="{Binding Settings.GameTransitionInterval}" HorizontalAlignment="Left"  Margin="0 0 5 0"/>
            <Label     Content="{p:LocalizedString {x:Static p:LocId.settings_game_trans}}"  HorizontalAlignment="Left"/>
        </StackPanel>
        <StackPanel Grid.Row="14" Grid.ColumnSpan="2" Orientation="Horizontal">
            <l:UIntDUp Value="{Binding Settings.ScreenSaverInterval}" HorizontalAlignment="Left"  Margin="0 0 5 0"/>
            <Label     Content="{p:LocalizedString {x:Static p:LocId.settings_svr_interval}}"  HorizontalAlignment="Left"/>
        </StackPanel>
        <Label     Grid.Row="16"                   Name="MonitorLabel"      Content="{p:LocalizedString {x:Static p:LocId.settings_monitor}}" d:LayoutOverrides="VerticalAlignment"/>
        <ComboBox  Grid.Row="16"  Grid.Column="1"  Name="MonitorCombo"      SelectedValue="{Binding Settings.MonitorName}" Height="20"/>
        <Label     Grid.Row="18"                   Name="PlayStateLabel"    Content="{p:LocalizedString {x:Static p:LocId.settings_play_state}}" d:LayoutOverrides="VerticalAlignment"/>
        <ComboBox  Grid.Row="18"  Grid.Column="1"  Name="PlayStateCombo"    SelectedIndex="{Binding Settings.PlayState, Converter={c:PlayStateConverter}}" Height="20">
            <ComboBoxItem Content="{p:LocalizedString {x:Static p:LocId.settings_enum_play_state_never}}"/>
            <ComboBoxItem Content="{p:LocalizedString {x:Static p:LocId.settings_enum_play_state_desktop}}"/>
            <ComboBoxItem Content="{p:LocalizedString {x:Static p:LocId.settings_enum_play_state_fullscreen}}"/>
            <ComboBoxItem Content="{p:LocalizedString {x:Static p:LocId.settings_enum_play_state_always}}"/>
        </ComboBox>
    </Grid>
</UserControl>
